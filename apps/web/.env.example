# Weather App — web env (example). Copy to .env.local. NO real secrets here.
#
# Supabase is OPTIONAL: the app builds and runs (signed-out weather browsing)
# without these. Set them to enable auth, favorites sync, and preferences sync.

# Supabase project URL (public, safe in the browser bundle).
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key (public, safe in the browser bundle).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service-role key (SERVER ONLY — never exposed to the client bundle).
SUPABASE_SERVICE_ROLE_KEY=

# Error tracking DSN (optional). Without it, error tracking is a no-op.
ERROR_TRACKING_DSN=

# Base URL for the remote Next.js API (desktop/static-export targets this).
NEXT_PUBLIC_API_BASE_URL=
